{
  "Security": {
    "AllowedRootPaths": [
      "/home/user/projects",
      "C:\\dev",
      "C:\\Users"
    ]
  },
  "LanguageServers": {
    "TypeScript": {
      "Command": "typescript-language-server",
      "Args": ["--stdio"]
    },
    "Python": {
      "Command": "pyright-langserver",
      "Args": ["--stdio"]
    },
    "Go": {
      "Command": "gopls",
      "Args": []
    },
    "Cpp": {
      "Command": "clangd",
      "Args": ["--background-index"]
    },
    "Java": {
      "Command": "jdtls",
      "Args": []
    },
    "Rust": {
      "Command": "rust-analyzer",
      "Args": []
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
